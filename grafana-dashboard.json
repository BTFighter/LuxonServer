{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "title": "Luxon Server Metrics",
  "uid": "luxon-dashboard-01",
  "tags": ["luxon", "enet", "photon", "game-server"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": "label_values(luxon_global_peers_current, instance)",
        "refresh": 1,
        "type": "query",
        "datasource": "${DS_PROMETHEUS}"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Current Peers",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(luxon_global_peers_current{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 5 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(luxon_global_connections_active{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Server Busy Time (1m Avg)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 5 },
      "id": 3,
      "targets": [
        {
          "expr": "avg(luxon_server_busy_time_1m_avg{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "continuous-GrYlRd" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Network Bandwidth",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(luxon_global_bytes_in_per_second{instance=~\"$instance\"})",
          "legendFormat": "Bytes In/s",
          "refId": "A"
        },
        {
          "expr": "sum(luxon_global_bytes_out_per_second{instance=~\"$instance\"})",
          "legendFormat": "Bytes Out/s",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Peer Disconnect Dynamics",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(luxon_global_disconnected_peers_client_per_second{instance=~\"$instance\"})",
          "legendFormat": "Client Disconnects",
          "refId": "A"
        },
        {
          "expr": "sum(luxon_global_disconnected_peers_server_per_second{instance=~\"$instance\"})",
          "legendFormat": "Server Kicks",
          "refId": "B"
        },
        {
          "expr": "sum(luxon_global_disconnected_peers_timeout_per_second{instance=~\"$instance\"})",
          "legendFormat": "Timeouts",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Timeouts" },
            "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "ENet Network Quality & Loss",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 9 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(luxon_enet_reliable_commands_in_dropped_per_second{instance=~\"$instance\"})",
          "legendFormat": "Dropped Incoming Reliable",
          "refId": "A"
        },
        {
          "expr": "sum(luxon_enet_reliable_commands_out_resent_per_second{instance=~\"$instance\"})",
          "legendFormat": "Resent Outgoing Reliable",
          "refId": "B"
        },
        {
          "expr": "sum(luxon_enet_unreliable_commands_in_dropped_per_second{instance=~\"$instance\"})",
          "legendFormat": "Dropped Unreliable",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Server Performance (Busy vs Idle)",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 14 },
      "id": 7,
      "targets": [
        {
          "expr": "avg(luxon_server_busy_time_1m_avg{instance=~\"$instance\"})",
          "legendFormat": "Busy Time (Avg)",
          "refId": "A"
        },
        {
          "expr": "max(luxon_server_busy_time_1m_max{instance=~\"$instance\"})",
          "legendFormat": "Busy Time (Max)",
          "refId": "B"
        },
        {
          "expr": "avg(luxon_server_idle_time_1m_avg{instance=~\"$instance\"})",
          "legendFormat": "Idle Time (Avg)",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Idle Time (Avg)" },
            "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash" } } ]
          }
        ]
      }
    }
  ]
}
